{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Bootstrap workspace",
            "type": "process",
            "hide": true,
            "command": "dart",
            "args": [
                "tool/bootstrap_workspace.dart"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "never",
                "panel": "shared",
                "clear": true,
                "close": true,
                "showReuseMessage": false,
                "focus": false,
                "echo": false
            },
            "problemMatcher": []
        },
        {
            "label": "Run Prepare (debug)",
            "type": "process",
            "hide": true,
            "command": "dart",
            "args": [
                "tool/project_tasks.dart",
                "run:prepare",
                "--debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "never",
                "panel": "shared",
                "clear": true,
                "close": true,
                "showReuseMessage": false,
                "focus": false,
                "echo": false
            },
            "problemMatcher": []
        },
